# Optional overrides for the demo. The defaults below are baked into
# docker-compose.yml, so for the local LocalStack demo you usually DO NOT need a
# .env at all. Copy to .env only if you want to change the Connect endpoint or
# (for a real-AWS run) supply real credentials/region.

# Where the Go client reaches the Spark Connect server.
#   in-compose : sc://spark-connect:15002 (default)
#   from host  : sc://localhost:15003   (this folder publishes Connect on host 15003)
SPARK_CONNECT_REMOTE=sc://spark-connect:15002

# --- AWS / LocalStack (already set in compose for the spark services) ---
# For the LocalStack demo these are test/test and the in-compose endpoint. The
# BUILT-IN AwsKeyManagementClient reads region from the catalog prop
# spark.sql.catalog.demo.client.region and the KMS endpoint from
# spark.sql.catalog.demo.kms.endpoint; credentials come from the AWS default
# credential chain, which picks up AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY.
# For a REAL AWS run: drop kms.endpoint (so the SDK uses the real KMS endpoint),
# set client.region + AWS_REGION, and provide real IAM credentials (or an
# instance/container role -- the SDK falls back to DefaultCredentialsProvider).
# The required IAM actions are: kms:GenerateDataKey, kms:Encrypt, kms:Decrypt.
# AWS_ENDPOINT_URL=http://localstack:4566
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=test
# AWS_SECRET_ACCESS_KEY=test
